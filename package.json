{
  "name": "@amartinr/pi-searxng",
  "version": "1.0.2",
  "description": "A minimalist SearXNG web search extension for Pi",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "prepublish": "npm run clean && npm run build"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0"
  },
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amartinr/pi-searxng.git"
  },
  "keywords": [
    "pi-package",
    "pi",
    "searxng",
    "web-search"
  ],
  "license": "MIT",
  "author": "A. Martin <abel.martin.ruiz@gmail.com>",
  "publishConfig": {
    "access": "public"
  }
}
